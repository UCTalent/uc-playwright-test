# 📝 E2E Test Configuration Template
# 
# Copy this file to .env and fill in your credentials
# ⚠️  IMPORTANT: Never commit .env file to version control
#

# 🔐 Test Account Credentials (Google OAuth)
# This account must have admin/reviewer permissions on UCTalent
TEST_GOOGLE_EMAIL = your-email@gmail.com
TEST_GOOGLE_PASSWORD = your-secure-password

# 🌐 Frontend URL
# Point to your development/staging/production environment
FRONTEND_URL = https://uctalent.dev
# For local testing:
# FRONTEND_URL = http://localhost:3000

# 🖥️  Browser Configuration
# Set to 'true' for headless mode (CI/CD), 'false' for headed mode (debugging)
HEADLESS = true

# ⏱️  Timeout Settings (milliseconds)
# DEFAULT_TIMEOUT = 30000
# NAVIGATION_TIMEOUT = 30000

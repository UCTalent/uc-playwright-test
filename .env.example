# Playwright E2E environment template

# Admin account used to refresh storageState.json manually.
TEST_GOOGLE_EMAIL=your-admin@example.com
TEST_GOOGLE_PASSWORD=your-secure-password

# Public app endpoints used by the tests.
FRONTEND_URL=https://uctalent.dev
BASE_URL=https://uctalent.dev
ATS_URL=https://business.uctalent.dev

# Backend/API endpoint that frontend and ATS are expected to use in dev.
API_BASE_URL=https://api.nest.uctalent.dev

# Auth mode:
# - reuse: use an existing storageState.json
# - refresh: open headed Chrome and refresh the session
CI_AUTH_MODE=reuse

# Optional: connect to an existing Chrome via CDP when refreshing auth.
# CHROME_CDP_URL=http://127.0.0.1:9222
